NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3002

# Sitemap, Open Graph ve mutlak URL'ler (örn. https://benimogretmenim.com)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# `next build` artık prod benzeri doğrulama yapar:
# - NEXT_PUBLIC_SITE_URL zorunlu
# - URL'ler https olmalı (local http için WEB_ALLOW_HTTP=1)
# WEB_ALLOW_HTTP=1

# Sunucu + next.config rewrites: gerçek API kökü (çoğu zaman NEXT_PUBLIC ile aynı).
# Prod’da NEXT_PUBLIC yanlışlıkla site köküne işaret ederse, INTERNAL doğru API’de kalmalı.
# INTERNAL_API_BASE_URL=http://127.0.0.1:3002

# apps/api/.env ile aynı olmalı; tanımlıysa admin havale proxy bu başlığı ekler
# ADMIN_API_SECRET=

# PayTR iFrame için backend env'leri (apps/api/.env içine konur)
# PAYTR_MERCHANT_ID=...
# PAYTR_MERCHANT_KEY=...
# PAYTR_MERCHANT_SALT=...
# PAYTR_BASE_URL=https://www.paytr.com
# PAYTR_CALLBACK_URL=https://<api-domain>/v1/paytr/callback
# PAYTR_OK_URL=http://localhost:3000/odeme/ok
# PAYTR_FAIL_URL=http://localhost:3000/odeme/hata

