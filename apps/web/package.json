{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/check-web-env.mjs",
    "start": "next start",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "check:role-features": "tsx scripts/check-role-features.ts",
    "check:uygulama-content": "tsx scripts/check-uygulama-content.ts",
    "test:e2e:install": "playwright install chromium --no-shell",
    "test:e2e": "playwright test",
    "test:e2e:public": "playwright test --grep-invert @integration",
    "test:e2e:integration": "playwright test --grep @integration",
    "test:e2e:ui": "playwright test --ui",
    "logo:strip-bg": "node scripts/remove-logo-bg.mjs"
  },
  "dependencies": {
    "benimogretmenim": "file:../..",
    "next": "^16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
