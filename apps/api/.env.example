PORT=3002

# Yerel Docker Compose (docker-compose.yml) ile uyumlu varsayılan
DATABASE_URL=postgres://benim:benim_dev_change_me@127.0.0.1:5432/benimogretmenim

# Bulut örnek (Neon): kendi connection string'inizi yapıştırın; sslmode=require önerilir
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES=7d

# Tarayıcıdan API’ye CORS (virgülle birden fazla). Boşsa yalnızca yerel Next (3000/3001) izinlidir.
# CORS_ORIGINS=https://app.sizin-domain.com,https://www.sizin-domain.com

# Bootstrap admin (npm run db:seed:admin) — kullanıcı adı = e-posta. Varsayılan: admin@benimogretmenim.local / BenimAdmin2026!
# ADMIN_BOOTSTRAP_EMAIL=
# ADMIN_BOOTSTRAP_PASSWORD=
# ADMIN_BOOTSTRAP_DISPLAY_NAME=

# Admin abonelik uçları (havale listesi / onay). Tanımlıysa istekte X-Admin-Secret başlığı zorunludur.
# Web arayüzü apps/web üzerindeki /api/admin/* proxy ile aynı değeri sunucuya ekler; tarayıcıya konmaz.
# ADMIN_API_SECRET=uzun-rastgele-dize

# Havale talimatı (öğretmen aboneliği)
# BANK_IBAN=TR00...
# BANK_ACCOUNT_NAME=BenimÖğretmenim
# BANK_TRANSFER_DESCRIPTION_PREFIX=BO-SUB

# PayTR iFrame (abonelik checkout)
# PAYTR_MERCHANT_ID=
# PAYTR_MERCHANT_KEY=
# PAYTR_MERCHANT_SALT=
# PAYTR_BASE_URL=https://www.paytr.com
# PAYTR_CALLBACK_URL=https://api.sizin-domain.com/v1/paytr/callback
# PAYTR_OK_URL=https://web.sizin-domain.com/odeme/ok   (Next: /odeme/ok)
# PAYTR_FAIL_URL=https://web.sizin-domain.com/odeme/hata
# PAYTR_TEST_MODE=1
# PAYTR_TIMEOUT_LIMIT=30
# PAYTR_DEBUG_ON=1

# Öğrenci platform aboneliği (kuruş/ay; 1000 TL = 100_000; ay sayısı ile çarpılır; PayTR /paytr/student-sub-checkout)
# STUDENT_SUB_PRICE_MINOR=100000
# Doğrudan ders: ödeme bittiğinde öğretmene (brüt, kuruş) — 1000 = %10 (DIRECT_LESSON_FEE_BPS=1000)
# DIRECT_LESSON_FEE_BPS=0

# Abonelik kampanya çarpanı (2 = süre x2)
# SUB_PROMO_MULTIPLIER=2

# Ücretsiz teklif limiti (30 gün, abonelik yokken)
# FREE_OFFER_LIMIT=3

# Teklifte önerilen saatlik ücret üst sınırı (kuruş; varsayılan 100_000_000 = 1.000.000 TL/saat)
# MAX_PROPOSED_HOURLY_RATE_MINOR=100000000

# Talep kabulüyle açılan varsayılan paket ders sayısı
# DEFAULT_PACKAGE_TOTAL_LESSONS=4

# Meeting link üretimi (varsayılan: https://meet.jit.si)
# MEETING_BASE_URL=https://meet.jit.si

# Docker CLI tam yolu (PATH sorununda): örnek
# DOCKER_PATH=C:\Program Files\Docker\Docker\resources\bin\docker.exe
