PORT=3002

# Production DB (Neon/Supabase/VPS)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# Auth
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS
JWT_EXPIRES=7d

# CORS (comma-separated)
CORS_ORIGINS=https://web.example.com,https://example.com

# Admin proxy protection (recommended)
ADMIN_API_SECRET=CHANGE_ME_TOO

# Optional bank transfer info (if you show bank instructions)
# BANK_IBAN=TR00...
# BANK_ACCOUNT_NAME=BenimÖğretmenim
# BANK_TRANSFER_DESCRIPTION_PREFIX=BO-SUB

# PayTR (only if enabled)
# PAYTR_MERCHANT_ID=
# PAYTR_MERCHANT_KEY=
# PAYTR_MERCHANT_SALT=
# PAYTR_BASE_URL=https://www.paytr.com
# PAYTR_CALLBACK_URL=https://api.example.com/v1/paytr/callback
# PAYTR_OK_URL=https://web.example.com/odeme/ok
# PAYTR_FAIL_URL=https://web.example.com/odeme/hata
# PAYTR_TEST_MODE=0

# Campaign
SUB_PROMO_MULTIPLIER=3

