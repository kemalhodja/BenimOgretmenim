{
  "name": "benimogretmenim",
  "private": true,
  "description": "BenimÖğretmenim monorepo kökü — Docker ile veritabanı",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:check": "npm run db:check --prefix apps/api",
    "db:migrate": "npm run db:migrate --prefix apps/api",
    "db:seed": "npm run db:seed --prefix apps/api",
    "setup": "npm run setup --prefix apps/api",
    "dev": "npm run dev --prefix apps/api",
    "web:dev": "npm run dev --prefix apps/web",
    "web:build": "npm run build --prefix apps/web",
    "web:start": "npm run start --prefix apps/web",
    "smoke": "npm run smoke --prefix apps/api",
    "smoke:prod": "npm run smoke:prod --prefix apps/api",
    "smoke:e2e": "npm run smoke:e2e --prefix apps/api",
    "smoke:suite": "npm run smoke:suite --prefix apps/api",
    "test": "npm run test --prefix apps/api",
    "ci:api": "npm ci --include=dev --prefix apps/api && npm run test --prefix apps/api && npm run build --prefix apps/api",
    "ci:web": "node scripts/ci-web.mjs",
    "ci": "npm run ci:api && npm run ci:web",
    "migrate": "npm run db:migrate",
    "seed": "npm run db:seed",
    "free-port": "npm run free-port --prefix apps/api --",
    "free:3001": "npm run free-port --prefix apps/api -- 3001",
    "free:3002": "npm run free-port --prefix apps/api -- 3002"
  }
}
